# LLM API Keys
BIOAGENT_ANTHROPIC_API_KEY=your-anthropic-api-key-here
BIOAGENT_OPENAI_API_KEY=your-openai-api-key-here

# Optional: NCBI API key for PubMed access
BIOAGENT_NCBI_API_KEY=

# Model Configuration
BIOAGENT_PRIMARY_MODEL=claude-sonnet-4-5-20250929
BIOAGENT_FALLBACK_MODEL=gpt-4.1
BIOAGENT_MAX_TOKENS=4096

# Execution
BIOAGENT_CODE_TIMEOUT=120
BIOAGENT_MAX_ITERATIONS=5
BIOAGENT_MAX_TOOL_CALLS=20

# Checkpointing
BIOAGENT_CHECKPOINT_DIR=checkpoints
BIOAGENT_USE_SQLITE_CHECKPOINTS=true

# Human-in-the-loop
BIOAGENT_HUMAN_IN_LOOP=false
BIOAGENT_REVIEW_BEFORE_EXECUTION=false
BIOAGENT_REVIEW_BEFORE_SUBMISSION=true

# Workspace
BIOAGENT_WORKSPACE_DIR=workspace

# Logging
BIOAGENT_LOG_LEVEL=INFO
BIOAGENT_LOG_FILE=lyceumai.log
